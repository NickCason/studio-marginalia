{
  "name": "blue-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tinacms dev -c \"astro dev\"",
    "dev:astro": "astro dev",
    "dev:host": "tinacms dev -c \"astro dev --host 0.0.0.0\"",
    "build": "tinacms build --skip-cloud-checks && astro build",
    "build:astro": "astro build",
    "preview": "astro preview",
    "preview:host": "astro preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "playwright test",
    "tts": "node scripts/tts.mjs",
    "deploy": "wrangler pages deploy ./dist --project-name=blue-studio"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.1",
    "@astrojs/react": "^5.0.5",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.4.1",
    "@fontsource-variable/fraunces": "^5.2.6",
    "@fontsource-variable/inter": "^5.2.6",
    "@keystatic/astro": "^5.0.6",
    "@keystatic/core": "^0.5.50",
    "@phosphor-icons/web": "^2.1.2",
    "@resvg/resvg-js": "^2.6.2",
    "@tinacms/cli": "^2.2.5",
    "astro": "^5.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "satori": "^0.26.0",
    "tinacms": "^3.7.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.10.5",
    "audio-decode": "^2.2.2",
    "sharp": "^0.33.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
