---
import type { CollectionEntry } from 'astro:content';
import TagList from '~/components/ui/TagList.astro';
import { formatDate } from '~/lib/formatDate';
interface Props { post: CollectionEntry<'posts'>; }
const { post } = Astro.props;
if (post.data.type !== 'gallery') throw new Error();

const images = post.data.images;
---
<article class="permalink gallery-perma">
  <div class="carousel" data-gallery-carousel data-index="0">
    <div class="stage">
      {images.map((img, i) => (
        <div class="slide" data-slide-index={i} data-pos={i === 0 ? 'active' : 'hidden'}>
          <img
            src={img.src}
            alt={img.caption ?? ''}
            data-photo-lightbox
            data-lightbox-caption={img.caption ?? ''}
          />
        </div>
      ))}
    </div>
    {images.length > 1 && (
      <>
        <button type="button" class="nav prev" data-nav-prev aria-label="Previous photo">‹</button>
        <button type="button" class="nav next" data-nav-next aria-label="Next photo">›</button>
        <div class="dots" role="tablist" aria-label="Gallery navigation">
          {images.map((_, i) => (
            <button type="button" class="dot" data-dot-index={i} aria-label={`Photo ${i + 1}`} aria-selected={i === 0 ? 'true' : 'false'}></button>
          ))}
        </div>
      </>
    )}
  </div>
  {images[0].caption && <p class="cap serif-italic" data-active-caption>— {images[0].caption}</p>}
  <div class="date eyebrow">{formatDate(post.data.publishedAt)} · {images.length} photos</div>
  <TagList tags={post.data.tags} />
</article>

<style>
  .permalink { padding: 40px 0; max-width: 1100px; margin: 0 auto; }
  .carousel { position: relative; user-select: none; touch-action: pan-y; margin-bottom: 22px; }
  .stage {
    position: relative;
    height: clamp(360px, 72vw, 720px);
    perspective: 1600px;
    overflow: visible;
  }
  .slide {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 70%;
    max-width: 820px;
    transform: translate(-50%, -50%) scale(0.55);
    opacity: 0;
    pointer-events: none;
    transition:
      transform 560ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 400ms ease,
      filter 400ms ease;
    will-change: transform, opacity;
    z-index: 1;
  }
  .slide img {
    display: block;
    width: 100%;
    height: auto;
    max-height: clamp(340px, 70vw, 700px);
    object-fit: contain;
    border-radius: var(--r-xl);
    box-shadow: var(--shadow-stage);
  }
  .slide[data-pos="active"] {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
    pointer-events: auto;
    z-index: 3;
    filter: none;
  }
  .slide[data-pos="prev"] {
    transform: translate(calc(-50% - 72%), -50%) scale(0.74) rotateY(10deg);
    opacity: 0.45;
    z-index: 2;
    filter: saturate(0.85) brightness(0.9);
  }
  .slide[data-pos="next"] {
    transform: translate(calc(-50% + 72%), -50%) scale(0.74) rotateY(-10deg);
    opacity: 0.45;
    z-index: 2;
    filter: saturate(0.85) brightness(0.9);
  }
  .nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.42);
    color: rgba(255, 255, 255, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.18);
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(6px);
    transition: background var(--t-fast, 180ms) ease, transform 180ms ease;
  }
  .nav:hover { background: rgba(0, 0, 0, 0.62); }
  .nav:active { transform: translateY(-50%) scale(0.94); }
  .prev { left: 12px; }
  .next { right: 12px; }
  :root[data-theme='light'] .nav {
    background: rgba(255, 255, 255, 0.78);
    color: var(--fg);
    border-color: rgba(0, 0, 0, 0.12);
  }
  :root[data-theme='light'] .nav:hover { background: rgba(255, 255, 255, 0.96); }
  .dots { display: flex; gap: 10px; justify-content: center; margin-top: 18px; }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--rule-dotted, rgba(255, 255, 255, 0.25));
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background var(--t-fast, 180ms) ease, transform 180ms ease;
  }
  .dot[aria-selected="true"] { background: var(--accent); transform: scale(1.4); }
  .cap { font-size: 19px; opacity: 0.9; max-width: 56ch; margin: 0 auto 14px; text-align: center; }
  .date { color: var(--accent); margin-bottom: 16px; }
  @media (prefers-reduced-motion: reduce) {
    .slide { transition: opacity 200ms ease; }
    .slide[data-pos="prev"], .slide[data-pos="next"] { transform: translate(-50%, -50%) scale(1); opacity: 0; }
  }
</style>
