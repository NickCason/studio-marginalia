---
export const prerender = true;
import { getCollection } from 'astro:content';
import Base from '~/layouts/Base.astro';

// Keep the slug routes alive so old bookmarks resolve to the under-construction
// overlay instead of 404ing. When the portfolio launches, this file goes back
// to rendering the full case study (see /preview/work/portfolio/[slug].astro
// for the source template).
export async function getStaticPaths() {
  const cases = await getCollection('portfolio');
  return cases.map((entry) => ({ params: { slug: entry.slug } }));
}
---
<Base
  title="Selected work — Blue Studio"
  description="The studio's portfolio is being re-set. New case studies are landing soon."
>
  <section class="page">
    <div class="card">
      <div class="eyebrow"><span /><span>The studio is rearranging</span><span /></div>
      <h1 class="hed serif-italic">A quiet remodel<br /><em class="amp">is underway</em>.</h1>
      <p class="sub serif">This case study is being re-set with the rest of the portfolio. It'll open back up in a few weeks. In the meantime, you can read the journal, peek at the about page, or write to me directly.</p>
      <div class="actions">
        <a href="/" class="cta">Read the journal <i class="ph-duotone ph-arrow-right"></i></a>
        <a href="/work/#contact" class="cta-quiet">Or send a note <i class="ph-duotone ph-arrow-up-right"></i></a>
      </div>
      <div class="sparkle-row" aria-hidden="true">
        <i class="ph-duotone ph-flower"></i>
        <i class="ph-duotone ph-asterisk"></i>
        <i class="ph-duotone ph-flower"></i>
      </div>
    </div>
  </section>
</Base>

<style>
  .page {
    min-height: calc(100vh - 200px);
    padding: 56px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card {
    max-width: 640px;
    text-align: center;
    padding: 64px 48px 56px;
    background: linear-gradient(135deg, rgba(110, 90, 138, 0.16), rgba(42, 30, 52, 0.4));
    border: 1px solid var(--card-edge);
    border-radius: var(--r-lg);
    backdrop-filter: blur(10px);
    box-shadow: inset 0 1px 0 var(--inset-sheen), 0 24px 60px -20px rgba(110, 90, 138, 0.45);
    position: relative;
    overflow: hidden;
  }
  :root[data-theme='light'] .card {
    background: linear-gradient(135deg, rgba(110, 90, 138, 0.10), rgba(42, 30, 52, 0.06));
  }
  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 0%, rgba(110, 90, 138, 0.28), transparent 60%);
    pointer-events: none;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    font-size: 11px;
    letter-spacing: var(--tracking-cap);
    text-transform: uppercase;
    color: var(--accent-text);
    font-weight: 500;
    position: relative;
  }
  .eyebrow > span:first-child,
  .eyebrow > span:last-child {
    width: 32px;
    height: 1px;
    background: var(--accent-text);
    opacity: 0.5;
  }
  .hed {
    font-size: clamp(2rem, 5.5vw, 3.25rem);
    line-height: 1.05;
    margin: 0 0 24px;
    font-weight: 300;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 32px rgba(110, 90, 138, 0.5);
    font-variation-settings: 'SOFT' 100, 'opsz' 144;
    position: relative;
  }
  :root[data-theme='light'] .hed { text-shadow: none; }
  .hed em.amp {
    color: var(--accent);
    font-style: italic;
    font-weight: 300;
  }
  .sub {
    font-size: 17px;
    line-height: 1.55;
    color: var(--fg-soft);
    max-width: 48ch;
    margin: 0 auto 36px;
    opacity: 0.92;
    position: relative;
  }
  .actions {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 36px;
    position: relative;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 13px 26px;
    border: 1px solid var(--accent);
    background: rgba(110, 90, 138, 0.18);
    color: var(--fg);
    border-radius: var(--r-pill);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .cta:hover { background: var(--accent); color: var(--np-ink); }
  .cta i { font-size: 14px; }
  .cta-quiet {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 22px;
    border: 1px solid var(--border-soft);
    color: var(--fg-soft);
    border-radius: var(--r-pill);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .cta-quiet:hover { color: var(--fg); border-color: var(--accent-text); }
  .cta-quiet i { font-size: 14px; }
  .sparkle-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    color: var(--accent-text);
    opacity: 0.45;
    font-size: 18px;
    position: relative;
  }
  .sparkle-row i:nth-child(2) { font-size: 12px; opacity: 0.7; }
  @media (max-width: 640px) {
    .card { padding: 48px 28px 40px; }
  }
</style>
