---
export const prerender = true;
import { getCollection, getEntry } from 'astro:content';
import Base from '~/layouts/Base.astro';

const entry = await getEntry('workPage', 'work');
if (!entry) throw new Error('Missing src/content/workPage/work.json');
const { seo, hero, services, fit, contact } = entry.data;

const formspree = import.meta.env.PUBLIC_FORMSPREE_ENDPOINT || '';
const allCases = await getCollection('portfolio');
const cases = allCases
  .sort((a, b) => (a.data.order - b.data.order) || (b.data.year - a.data.year))
  .slice(0, 3);
---
<Base title={`${seo.title} (preview)`} description={seo.description} noindex>
  <div class="preview-banner" role="note">
    <i class="ph-duotone ph-eye"></i>
    Preview — this version is for you. The live site is at <a href="/work/">/work/</a>.
  </div>

  <section class="hero">
    <div class="eyebrow eyebrow-rule"><span /><span>{hero.eyebrow}</span><span /></div>
    <h1 class="hed serif-italic">{hero.heading}<br /><em class="amp">{hero.headingAmp}</em>.</h1>
    <p class="sub serif">{hero.sub}</p>
    <a href="#contact" class="cta">{hero.ctaLabel} <i class="ph-duotone ph-arrow-right"></i></a>
  </section>

  <section class="services">
    <div class="section-label"><span>✦</span><span>{services.eyebrow}</span><span>✦</span></div>
    <div class="grid">
      {services.items.map((item) => (
        <div class="card">
          <i class={`ph-duotone ${item.icon}`}></i>
          <h4 class="serif-italic">{item.title}</h4>
          <p>{item.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="fit">
    <div class="section-label"><span>✦</span><span>{fit.eyebrow}</span><span>✦</span></div>
    <div class="grid">
      <div class="yes">
        <h5 class="serif-italic">{fit.yesHeading}</h5>
        <ul>
          {fit.yesItems.map((item) => (
            <li><i class="ph-duotone ph-check-circle"></i>{item}</li>
          ))}
        </ul>
      </div>
      <div class="no">
        <h5 class="serif-italic">{fit.noHeading}</h5>
        <ul>
          {fit.noItems.map((item) => (
            <li><i class="ph-duotone ph-x-circle"></i>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="selected-work">
    <div class="section-label"><span>✦</span><span>Selected work</span><span>✦</span></div>
    <div class="tiles">
      {cases.map((c) => {
        const styleStr = c.data.image
          ? `background-image:url(${c.data.image});background-size:cover;background-position:center;`
          : 'background:linear-gradient(135deg,var(--np-rose),var(--np-amethyst));';
        return (
          <a class="tile" href={`/preview/work/portfolio/${c.slug}/`}>
            <div class="tile-img" style={styleStr}></div>
            <div class="tile-meta">
              <div class="tile-year">{c.data.year}</div>
              <div class="tile-name serif-italic">{c.data.name}</div>
            </div>
          </a>
        );
      })}
    </div>
    <div class="see-all">
      <a href="/preview/work/portfolio/" class="see-all-link">See all work <i class="ph-duotone ph-arrow-right"></i></a>
    </div>
  </section>

  <section class="contact" id="contact">
    <h3 class="serif-italic">{contact.heading}</h3>
    <p class="sub-small">{contact.sub}</p>
    {formspree ? (
      <form class="form" action={formspree} method="POST">
        <input type="text" name="name" placeholder={contact.namePlaceholder} required />
        <input type="email" name="email" placeholder={contact.emailPlaceholder} required />
        <textarea name="message" placeholder={contact.messagePlaceholder} required></textarea>
        <button type="submit">{contact.submitLabel} <i class="ph-duotone ph-paper-plane-tilt"></i></button>
      </form>
    ) : (
      <p class="form-fallback serif-italic">Email <a href={`mailto:${contact.fallbackEmail}`}>{contact.fallbackEmail}</a> for now.</p>
    )}
  </section>
</Base>

<style>
  .preview-banner {
    background: rgba(110, 90, 138, 0.18);
    border-bottom: 1px solid var(--accent);
    padding: 10px 24px;
    text-align: center;
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--fg);
  }
  .preview-banner i { color: var(--accent-text); margin-right: 6px; }
  .preview-banner a { color: var(--accent-text); border-bottom: 1px dotted var(--accent-text); }

  .hero { padding: 72px 56px 56px; text-align: center; }
  .eyebrow-rule { display: inline-flex; align-items: center; gap: 12px; margin-bottom: 24px; font-size: 11px; letter-spacing: var(--tracking-cap); text-transform: uppercase; color: var(--accent-text); font-weight: 500; }
  .eyebrow-rule > span:first-child, .eyebrow-rule > span:last-child { width: 24px; height: 1px; background: var(--accent-text); opacity: 0.5; }
  .hed { font-size: clamp(2.25rem, 6vw, 3.625rem); line-height: 1.05; margin: 0 auto 24px; max-width: 18ch; font-weight: 300; letter-spacing: -0.02em; text-shadow: 0 2px 32px rgba(110,90,138,0.5); font-variation-settings: 'SOFT' 100, 'opsz' 144; }
  :root[data-theme='light'] .hed { text-shadow: none; }
  .hed em.amp { color: var(--accent); font-style: normal; font-weight: 300; }
  .sub { font-size: 18px; line-height: 1.55; color: var(--fg-soft); max-width: 56ch; margin: 0 auto 36px; opacity: 0.92; }
  .cta { display: inline-flex; align-items: center; gap: 10px; padding: 14px 28px; border: 1px solid var(--accent); background: rgba(110,90,138,0.18); color: var(--fg); border-radius: var(--r-pill); font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 500; box-shadow: var(--shadow-card); }
  .cta:hover { background: var(--accent); color: var(--np-ink); }
  .cta i { font-size: 16px; }

  .services, .fit { padding: 64px 56px; border-top: 1px dashed var(--border-dashed); }
  .section-label { display: flex; align-items: center; justify-content: center; gap: 12px; font-size: 11px; letter-spacing: var(--tracking-cap); text-transform: uppercase; color: var(--accent-text); margin-bottom: 32px; }
  .section-label > span:first-child, .section-label > span:last-child { opacity: 0.6; }
  .services .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 28px; max-width: 800px; margin: 0 auto; }
  .services .card { padding: 24px 24px 22px; background: var(--card-tint); border: 1px solid var(--card-edge); border-radius: var(--r-lg); }
  .services .card i { font-size: 28px; color: var(--accent); margin-bottom: 14px; display: block; }
  .services .card h4 { font-size: 22px; line-height: 1.2; margin: 0 0 8px; color: var(--fg); font-weight: 400; }
  .services .card p { font-size: 14px; line-height: 1.55; color: var(--fg-soft); margin: 0; opacity: 0.9; }

  .fit { background: rgba(15,15,20,0.4); }
  :root[data-theme='light'] .fit { background: rgba(232,228,223,0.5); }
  .fit .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; max-width: 800px; margin: 0 auto; }
  .fit h5 { font-size: 20px; color: var(--fg); margin: 0 0 14px; font-weight: 400; }
  .fit ul { list-style: none; padding: 0; margin: 0; }
  .fit li { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 10px; color: var(--fg-soft); line-height: 1.5; }
  .fit li i { font-size: 16px; margin-top: 2px; flex-shrink: 0; }
  .fit .yes i { color: var(--np-moss); }
  .fit .no i { color: var(--np-rose); }

  .contact { padding: 64px 56px 96px; border-top: 1px dashed var(--border-dashed); text-align: center; }
  .contact h3 { font-size: 32px; margin: 0 0 12px; font-weight: 400; }
  .sub-small { font-size: 14px; opacity: 0.85; margin: 0 0 28px; color: var(--fg-soft); }
  .form { max-width: 500px; margin: 0 auto; text-align: left; }
  .form input, .form textarea { width: 100%; padding: 14px 18px; background: rgba(232,228,223,0.04); border: 1px solid var(--border-soft); border-radius: var(--r-md); color: var(--fg); font-family: inherit; font-size: 14px; margin-bottom: 12px; }
  :root[data-theme='light'] .form input, :root[data-theme='light'] .form textarea { background: rgba(42,30,52,0.04); }
  .form textarea { min-height: 120px; resize: vertical; font-family: 'Fraunces Variable', Georgia, serif; font-style: italic; font-size: 16px; line-height: 1.5; }
  .form button { background: var(--accent); color: var(--np-ink); border: none; padding: 14px 28px; border-radius: var(--r-pill); font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 600; box-shadow: var(--glow-amethyst); }
  .form-fallback a { color: var(--accent-text); border-bottom: 1px dotted var(--accent-text); }

  @media (max-width: 760px) {
    .hero, .services, .fit, .contact { padding-left: 20px; padding-right: 20px; }
    .services .grid, .fit .grid { grid-template-columns: 1fr; gap: 28px; }
  }

  .selected-work { padding: 64px 56px; border-top: 1px dashed var(--border-dashed); }
  .selected-work .tiles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; max-width: 900px; margin: 0 auto 28px; }
  .tile { border-radius: var(--r-md); overflow: hidden; border: 1px solid var(--border-soft); background: rgba(15,15,20,0.5); transition: transform 500ms var(--ease), box-shadow 500ms var(--ease), border-color 500ms var(--ease); position: relative; }
  :root[data-theme='light'] .tile { background: rgba(232,228,223,0.5); }
  .tile-img { height: 140px; transition: transform 600ms var(--ease); transform-origin: center; }
  a.tile { color: inherit; }
  a.tile::after {
    content: '→';
    position: absolute;
    bottom: 14px;
    right: 14px;
    font-size: 12px;
    color: var(--accent-text);
    opacity: 0.4;
    transition: opacity 300ms var(--ease), transform 300ms var(--ease);
  }
  @media (hover: hover) and (pointer: fine) {
    a.tile:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 28px -10px rgba(110, 90, 138, 0.4);
      border-color: var(--accent);
    }
    a.tile:hover .tile-img { transform: scale(1.04); }
    a.tile:hover::after { opacity: 1; transform: translateX(3px); }
  }
  .tile-meta { padding: 12px 14px 14px; }
  .tile-year { font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase; color: var(--accent-text); margin-bottom: 4px; }
  .tile-name { font-size: 16px; line-height: 1.25; color: var(--fg); }
  .see-all { text-align: center; }
  .see-all-link { display: inline-flex; align-items: center; gap: 8px; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--accent-text); border-bottom: 1px dotted var(--accent-text); padding-bottom: 2px; }
  .see-all-link i { font-size: 14px; }
  @media (max-width: 760px) {
    .selected-work { padding-left: 20px; padding-right: 20px; }
    .selected-work .tiles { grid-template-columns: 1fr; gap: 16px; }
  }
</style>
