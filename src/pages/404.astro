---
export const prerender = true;
import Base from '~/layouts/Base.astro';
---
<Base title="Critical fail — Blue Studio">
  <section class="page">
    <div class="d20-big">
      <span class="num serif-italic">1</span>
    </div>
    <h1 class="hed serif-italic">Critical fail.</h1>
    <p>That page isn't here. Try the <a href="/">journal</a>, or the <a href="/work/">work page</a>.</p>
  </section>
</Base>
<style>
  .page { padding: 120px 36px; text-align: center; max-width: 40ch; margin: 0 auto; }
  .d20-big { display: inline-flex; align-items: center; justify-content: center; width: 120px; height: 120px; position: relative; margin-bottom: 28px; }
  .d20-big::before { content: ''; position: absolute; inset: 0; background: var(--np-rose); clip-path: polygon(50% 0%, 100% 38%, 82% 100%, 18% 100%, 0% 38%); opacity: 0.9; }
  .d20-big .num { position: relative; font-size: 56px; color: var(--np-bone); font-weight: 600; }
  .hed { font-size: 36px; margin: 0 0 12px; font-weight: 400; }
  p { color: var(--fg-soft); }
  a { color: var(--accent); border-bottom: 1px dotted var(--accent); }
</style>
