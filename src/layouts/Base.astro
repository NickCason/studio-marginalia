---
import '~/styles/global.css';
import '@phosphor-icons/web/duotone';
import '@phosphor-icons/web/regular';
import '@phosphor-icons/web/fill';
import Nav from '~/components/layout/Nav.astro';
import Footer from '~/components/layout/Footer.astro';
import Sparkles from '~/components/atmosphere/Sparkles.astro';
import GlowStage from '~/components/atmosphere/GlowStage.astro';
import PhotoLightbox from '~/components/PhotoLightbox.astro';
import DeskFooter from '~/components/atmosphere/DeskFooter.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}
const {
  title = 'Blue Studio — Nina Pfeiffer',
  description = 'A personal-first journal and a quiet marketing studio. Essays, notes, and voice memos by Nina Pfeiffer.',
  ogImage = '/og-default.png',
  type = 'website',
  noindex = false,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://bluestudio.space').toString();
const siteUrl = 'https://bluestudio.space';
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0F0F14" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="alternate" type="application/rss+xml" title="Blue Studio" href="/rss.xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:type" content={type ?? 'website'} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={fullOgImage} />
    <script is:inline>
      (function () {
        function getTheme() {
          try {
            var stored = localStorage.getItem('sm-theme');
            if (stored === 'dark' || stored === 'light') return stored;
            return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
          } catch (e) { return 'dark'; }
        }
        // Initial application before paint.
        document.documentElement.setAttribute('data-theme', getTheme());
        // Re-apply on every View Transitions soft-nav. The new document's <html>
        // arrives without data-theme; we paint it before the swap so there's no flash.
        document.addEventListener('astro:before-swap', function (ev) {
          try { ev.newDocument.documentElement.setAttribute('data-theme', getTheme()); } catch (e) {}
        });
        // Optional: react live to system-pref changes when the user has not chosen explicitly.
        try {
          var mql = window.matchMedia('(prefers-color-scheme: light)');
          mql.addEventListener('change', function () {
            if (!localStorage.getItem('sm-theme')) {
              document.documentElement.setAttribute('data-theme', getTheme());
            }
          });
        } catch (e) {}
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <Sparkles />
    <GlowStage class="page">
      <Nav />
      <main>
        <slot />
      </main>
      <Footer />
    </GlowStage>
    <PhotoLightbox transition:persist />
    <DeskFooter transition:persist />
    <style is:global>
      .page { min-height: 100vh; }
      main { position: relative; z-index: 2; }
    </style>
  </body>
</html>
